# latamfx-mcp — cuenta GitHub aislada (direnv), grupo personal (floreskemec).
# Antes: gh compartia ~/.config/gh con uvix -> la cuenta "activa" quedaba en el estado
# que dejara la ultima sesion, sin garantia (ver gotcha 2026-07-01).
# Sin secretos: solo fija que gh CLI use el config aislado de esta cuenta.
# Primera vez: brew install direnv (+ eval "$(direnv hook zsh)" en ~/.zshrc), luego: direnv allow
export GH_CONFIG_DIR="${HOME}/.config/gh-floreskemec"
